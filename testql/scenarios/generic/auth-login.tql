# auth-login.tql — generic authentication login test template
# Usage: testql scenarios/generic/auth-login.tql --url http://localhost:8101

LOG "=== Auth Login Test ==="

SET api_url "$TARGET_URL"

API POST "/api/v3/auth/login" {"username": "admin", "password": "admin"}
ASSERT_OK
ASSERT_CONTAINS "token"
LOG "login OK — token received"

LOG "=== Auth Login PASSED ==="
