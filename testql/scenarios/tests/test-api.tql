# Example DSL Script - API Testing
# 
# Run with:
#   ./scripts/dsl-run.sh scripts/examples/test-api.dsl
#   ./scripts/dsl-run.sh scripts/examples/test-api.dsl --url http://localhost:8101
#
# DSL Format: COMMAND target [key=value ...]

# Set up
LOG Starting API test

# Test devices endpoint
API GET /api/v3/data/devices?limit=5
ASSERT_STATUS 200

# Test customers endpoint  
API GET /api/v3/data/customers?limit=5
ASSERT_STATUS 200

# Test intervals endpoint
API GET /api/v3/data/intervals?limit=5
ASSERT_STATUS 200

# Test scenarios endpoint
API GET /api/v3/data/test_scenarios?limit=5
ASSERT_STATUS 200

# Short delay
WAIT 100

# Test menu configurations
API GET /api/v3/menu/configurations?limit=10
ASSERT_STATUS 200

LOG API test completed
