# test-gui-connect-id.iql — GUI tests for Connect ID module
# Tests: mouse+keyboard navigation, encoder navigation, page content verification
# Usage: python -m interpreter.iql tests/test-gui-connect-id.iql
#   or:  python -m interpreter.iql --dry-run tests/test-gui-connect-id.iql

SET encoder_url "http://localhost:8105"
SET api_url "http://localhost:8101"

LOG "=== Connect ID — GUI Test Suite ==="

# ═══════════════════════════════════════════════════════════════════════════════
# Part 1: Mouse + Keyboard Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 1: Mouse + Keyboard ---"

# 1.1 Navigate to Connect ID module
NAVIGATE "/connect-id"
WAIT 500

# 1.2 Verify top bar shows correct title (header moved from page-content to top bar)
LOG "Verify: top-bar-section-title should show Connect ID page title"

# 1.3 Navigate to RFID subpage
NAVIGATE "/connect-id/rfid"
WAIT 300

# 1.4 Verify RFID scanner panel is present
LOG "Verify: RFID scanner panel with Auto/Ręcznie tabs"

# 1.5 Click simulate scan button
CLICK "#btn-simulate-scan"
WAIT 200
LOG "Verify: new scan row appears in table"

# 1.6 Navigate to QR subpage
NAVIGATE "/connect-id/qr"
WAIT 300
LOG "Verify: QR scanner panel with Camera/File/Manual tabs"

# 1.7 Navigate to Manual (login) subpage
NAVIGATE "/connect-id/manual"
WAIT 300
LOG "Verify: username select + password input + virtual keyboard"

# 1.8 Navigate to List subpage
NAVIGATE "/connect-id/list"
WAIT 300
LOG "Verify: users table with filters and add-user form"

# 1.9 Test filter input on List page
INPUT "#add-name" "Test User"
INPUT "#add-id" "TEST-001"
WAIT 100

# 1.10 Navigate to Barcode subpage
NAVIGATE "/connect-id/barcode"
WAIT 300
LOG "Verify: barcode scanner with device info"

# ═══════════════════════════════════════════════════════════════════════════════
# Part 2: Encoder Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 2: Encoder Mode ---"

# 2.1 Activate encoder
ENCODER_ON
WAIT 300
ENCODER_STATUS

# 2.2 Navigate col1 (main menu) to Connect ID
ENCODER_FOCUS "col1"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.3 Confirm → move to col2 (submenu)
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: encoder now in col2 (Connect ID submenu)"

# 2.4 Scroll through submenu items (RFID, QR, Manual, List, Barcode)
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
LOG "Verify: submenu item highlighted"

# 2.5 Confirm → move to col3 (page content)
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: encoder now in col3 (page content area)"

# 2.6 Navigate within page content (table rows on RFID/QR/List pages)
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.7 Click on row → move to col4 (row actions)
ENCODER_CLICK
WAIT 300
ENCODER_STATUS
LOG "Verify: encoder now in col4 (row actions: Wybierz button)"

# 2.8 Cancel → back to col3
ENCODER_DBLCLICK
WAIT 200
ENCODER_STATUS
LOG "Verify: encoder back in col3"

# 2.9 Cancel → back to col2
ENCODER_DBLCLICK
WAIT 200
ENCODER_STATUS
LOG "Verify: encoder back in col2"

# 2.10 Cancel → back to col1
ENCODER_DBLCLICK
WAIT 200
ENCODER_STATUS
LOG "Verify: encoder back in col1"

# 2.11 Deactivate encoder
ENCODER_OFF
WAIT 200

# ═══════════════════════════════════════════════════════════════════════════════
# Part 3: API Verification (data behind the views)
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 3: API Verification ---"

API GET "/api/v3/auth/users"
ASSERT_OK
LOG "Users API accessible"

LOG "=== Connect ID — GUI Test Complete ==="
