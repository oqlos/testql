# Example DSL Script - Devices CRUD Operations
# Tests create, read, update, delete for devices
# 
# Run with: python3 scripts/dsl-cli.py scripts/examples/test-devices-crud.dsl -u http://localhost:8101

LOG "🔧 Testing Devices CRUD operations" {"level": "info"}

# ============================================================================
# READ - List devices
# ============================================================================

API GET "/api/v3/data/devices?limit=10"
ASSERT_STATUS 200
LOG "Listed devices successfully" {"level": "info"}

# ============================================================================
# LIST - Customers
# ============================================================================

API GET "/api/v3/data/customers?limit=5"
ASSERT_STATUS 200
LOG "Listed customers" {"level": "info"}

# ============================================================================
# LIST - Intervals
# ============================================================================

API GET "/api/v3/data/intervals?limit=10"
ASSERT_STATUS 200
LOG "Listed intervals" {"level": "info"}

# ============================================================================
# LIST - SGI (Scenario-Goal-Interval assignments)
# ============================================================================

API GET "/api/v3/data/scenario_goal_intervals?limit=10"
ASSERT_STATUS 200
LOG "Listed SGI assignments" {"level": "info"}

LOG "✅ Devices CRUD test completed" {"level": "info"}
