# test-gui-connect-workshop.iql — GUI tests for Connect Workshop module
# Tests: mouse+keyboard navigation, encoder navigation, page content verification
# Usage: python -m interpreter.iql tests/test-gui-connect-workshop.iql
#   or:  python -m interpreter.iql --dry-run tests/test-gui-connect-workshop.iql

SET encoder_url "http://localhost:8105"
SET api_url "http://localhost:8101"

LOG "=== Connect Workshop — GUI Test Suite ==="

# ═══════════════════════════════════════════════════════════════════════════════
# Part 1: Mouse + Keyboard Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 1: Mouse + Keyboard ---"

# 1.1 Navigate to Connect Workshop module
NAVIGATE "/connect-workshop"
WAIT 500
LOG "Verify: top-bar-section-title updated, two-column layout with menu + content"

# 1.2 Requests search subpage
NAVIGATE "/connect-workshop/requests-search"
WAIT 300
LOG "Verify: two-pane layout — left filters + right results table"

# 1.3 Click search button
CLICK "[data-action='requests-search']"
WAIT 300
LOG "Verify: search triggered"

# 1.4 Click filter apply
CLICK "[data-action='filters-apply']"
WAIT 200
LOG "Verify: filters applied"

# 1.5 Services search subpage
NAVIGATE "/connect-workshop/services-search"
WAIT 300
LOG "Verify: services search with filters and table"

# 1.6 Transport search subpage
NAVIGATE "/connect-workshop/transport-search"
WAIT 300
LOG "Verify: transport search with filters and table"

# 1.7 Dispositions search subpage
NAVIGATE "/connect-workshop/dispositions-search"
WAIT 300
LOG "Verify: dispositions table with action buttons"

# 1.8 New request subpage
NAVIGATE "/connect-workshop/requests-new-request"
WAIT 300
LOG "Verify: new request form"

# ═══════════════════════════════════════════════════════════════════════════════
# Part 2: Encoder Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 2: Encoder Mode ---"

# 2.1 Activate encoder
ENCODER_ON
WAIT 300

# 2.2 Navigate to Connect Workshop in col1
ENCODER_FOCUS "col1"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.3 Confirm → col2 (Workshop submenu)
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: col2 shows Workshop submenu (Zgłoszenia, Serwisy, Transport, Dyspozycje)"

# 2.4 Navigate submenu
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.5 Confirm → col3 (page content — search results table)
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: col3 shows search results table"

# 2.6 Navigate table rows
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.7 Click row → col4 (actions: view, edit, close, report)
ENCODER_CLICK
WAIT 300
ENCODER_STATUS
LOG "Verify: col4 shows row action buttons"

# 2.8 Table pagination (if available)
ENCODER_PAGE_NEXT
WAIT 300
ENCODER_STATUS
ENCODER_PAGE_PREV
WAIT 300
ENCODER_STATUS

# 2.9 Cancel back to col1
ENCODER_DBLCLICK
WAIT 200
ENCODER_DBLCLICK
WAIT 200
ENCODER_DBLCLICK
WAIT 200
ENCODER_STATUS

ENCODER_OFF
WAIT 200

# ═══════════════════════════════════════════════════════════════════════════════
# Part 3: API Verification
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 3: API Verification ---"

API GET "/api/v3/data/customers?limit=5"
ASSERT_OK
LOG "Customers API accessible"

LOG "=== Connect Workshop — GUI Test Complete ==="
