# connect-id-barcode.iql — Test: Identyfikacja > Barcode
# URL: /connect-id/barcode
# Run via: http://localhost:8105/files/tests/views/connect-id-barcode.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-id/barcode ==="

NAVIGATE "/connect-id/barcode"
WAIT 500
LOG "Verify: top-bar = 'Identyfikacja - Barcode', scan prompt + device info"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
LOG "Verify: col3 = test options (checkboxes + start/history buttons)"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-id/barcode ==="
