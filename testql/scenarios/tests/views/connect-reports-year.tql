# connect-reports-year.iql — Test: Raporty > Rok
# URL: /connect-reports/year?filter=all
# Run via: http://localhost:8105/files/tests/views/connect-reports-year.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-reports/year ==="

# ── Mouse + Keyboard ──
NAVIGATE "/connect-reports/year?filter=all"
WAIT 1500
ASSERT "#top-bar-section-title" text "Rok"
ASSERT ".quarter-card" exists
ASSERT ".year-summary" exists

# ── Encoder ──
ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ASSERT "[data-enc-zone='col3']" exists
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ASSERT ".encoder-focus" exists
ENCODER_CLICK
WAIT 300

# Move to second col3 zone (summary)
ENCODER_DBLCLICK
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
ASSERT ".encoder-focus" exists false
LOG "=== DONE: connect-reports/year ==="
