# connect-test-protocols.iql — Test: Testowanie > Raporty (protokoły)
# URL: /connect-test/protocols
# Run via: http://localhost:8105/files/tests/views/connect-test-protocols.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-test/protocols ==="

NAVIGATE "/connect-test/protocols"
WAIT 500
LOG "Verify: top-bar = 'Connect Test - Raporty', protocols table"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
LOG "Verify: col3 = protocols table rows"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

ENCODER_CLICK
WAIT 300
LOG "Verify: col4 = row actions (Podgląd, Link)"
ENCODER_STATUS

ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-test/protocols ==="
