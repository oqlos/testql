# connect-config-theme.iql — Test: Konfiguracja > Motyw
# URL: /connect-config-theme
# Run via: http://localhost:8105/files/tests/views/connect-config-theme.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-config-theme ==="

NAVIGATE "/connect-config-theme"
WAIT 500
LOG "Verify: top-bar = 'Connect Config - Motyw', theme selector with preview"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
LOG "Verify: theme option highlighted"
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-config-theme ==="
