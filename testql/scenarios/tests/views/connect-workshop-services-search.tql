# connect-workshop-services-search.iql — Test: Warsztat > Serwisy
# URL: /connect-workshop/services-search
# Run via: http://localhost:8105/files/tests/views/connect-workshop-services-search.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-workshop/services-search ==="

NAVIGATE "/connect-workshop/services-search"
WAIT 500
LOG "Verify: top-bar updated, services search with filters + table"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_CLICK
WAIT 300
LOG "Verify: col4 = row actions"
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-workshop/services-search ==="
