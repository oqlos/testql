# connect-test-testing-search.iql — Test: Testowanie > Wyszukiwanie testów
# URL: /connect-test/testing-search
# Run via: http://localhost:8105/files/tests/views/connect-test-testing-search.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-test/testing-search ==="

NAVIGATE "/connect-test/testing-search"
WAIT 500
LOG "Verify: top-bar updated, search bar + filter buttons + result-list"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
LOG "Verify: col3 = 'Wyniki wyszukiwania' (data-enc-zone on search-results)"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
LOG "Verify: result-item highlighted"

ENCODER_CLICK
WAIT 300
LOG "Verify: col4 = device-actions (Testuj / Szczegóły)"
ENCODER_STATUS

ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-test/testing-search ==="
