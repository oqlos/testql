# connect-reports-filter.iql — Test: Raporty > Filtruj
# URL: /connect-reports/filter?filter=all
# Run via: http://localhost:8105/files/tests/views/connect-reports-filter.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-reports/filter ==="

NAVIGATE "/connect-reports/filter?filter=all"
WAIT 500
LOG "Verify: top-bar = 'Raporty - Filtruj', two-column layout (filters + table)"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
LOG "Verify: col3 = GenericSearchPage table with protocols data"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-reports/filter ==="
