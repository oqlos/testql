# connect-manager-activities.iql — Test: Manager > Czynności
# URL: /connect-manager/activities
# Run via: http://localhost:8105/files/tests/views/connect-manager-activities.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-manager/activities ==="

NAVIGATE "/connect-manager/activities"
WAIT 500
LOG "Verify: top-bar = 'Manager - Czynności', activities table"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
LOG "Verify: activity row highlighted"
ENCODER_CLICK
WAIT 300
LOG "Verify: col4 = row actions"
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-manager/activities ==="
