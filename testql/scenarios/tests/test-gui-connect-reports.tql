# test-gui-connect-reports.iql — GUI tests for Connect Reports module
# Tests: mouse+keyboard navigation, encoder navigation, page content verification
# Usage: python -m interpreter.iql tests/test-gui-connect-reports.iql
#   or:  python -m interpreter.iql --dry-run tests/test-gui-connect-reports.iql

SET encoder_url "http://localhost:8105"
SET api_url "http://localhost:8101"

LOG "=== Connect Reports — GUI Test Suite ==="

# ═══════════════════════════════════════════════════════════════════════════════
# Part 1: Mouse + Keyboard Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 1: Mouse + Keyboard ---"

# 1.1 Navigate to Connect Reports module
NAVIGATE "/connect-reports"
WAIT 500
LOG "Verify: top-bar-section-title updated, menu + content layout"

# 1.2 Week report subpage
NAVIGATE "/connect-reports/week"
WAIT 300
LOG "Verify: weekly report view"

# 1.3 Month report subpage
NAVIGATE "/connect-reports/month"
WAIT 300
LOG "Verify: monthly report view"

# 1.4 Quarter report subpage
NAVIGATE "/connect-reports/quarter"
WAIT 300
LOG "Verify: quarterly report view"

# 1.5 Year report subpage
NAVIGATE "/connect-reports/year"
WAIT 300
LOG "Verify: yearly report view"

# 1.6 Custom report subpage
NAVIGATE "/connect-reports/custom"
WAIT 300
LOG "Verify: custom date range report"

# 1.7 Filter subpage
NAVIGATE "/connect-reports/filter"
WAIT 300
LOG "Verify: filter view with two-column layout"

# 1.8 Chart subpage
NAVIGATE "/connect-reports/chart"
WAIT 300
LOG "Verify: chart visualization page"

# ═══════════════════════════════════════════════════════════════════════════════
# Part 2: Encoder Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 2: Encoder Mode ---"

ENCODER_ON
WAIT 300

# 2.1 Navigate to Reports in col1
ENCODER_FOCUS "col1"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.2 Confirm -> col2 (Reports submenu)
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: col2 shows report period options"

# 2.3 Navigate submenu
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.4 Confirm -> col3 (report content)
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: col3 shows report table/chart content"

# 2.5 Navigate report rows
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.6 Table pagination
ENCODER_PAGE_NEXT
WAIT 300
ENCODER_STATUS
ENCODER_PAGE_PREV
WAIT 300

# 2.7 Cancel back
ENCODER_DBLCLICK
WAIT 200
ENCODER_DBLCLICK
WAIT 200
ENCODER_DBLCLICK
WAIT 200

ENCODER_OFF
WAIT 200

# ═══════════════════════════════════════════════════════════════════════════════
# Part 3: API Verification
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 3: API Verification ---"

API GET "/api/v3/data/protocols?limit=5"
ASSERT_OK
LOG "Protocols API accessible"

LOG "=== Connect Reports — GUI Test Complete ==="
