# connect-test-scenario-view.iql — Test: Testowanie > Scenariusz/Interwały
# URL: /connect-test/scenario-view
# Run via: http://localhost:8105/files/tests/views/connect-test-scenario-view.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-test/scenario-view ==="

NAVIGATE "/connect-test/scenario-view"
WAIT 500
LOG "Verify: top-bar = 'Connect Test - Scenariusz/Interwały'"
LOG "Verify: scenario selector + DSL viewer + toolbar"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-test/scenario-view ==="
