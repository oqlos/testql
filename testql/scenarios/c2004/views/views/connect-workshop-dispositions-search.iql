# connect-workshop-dispositions-search.iql — Test: Warsztat > Dyspozycje
# URL: /connect-workshop/dispositions-search
# Run via: http://localhost:8105/files/tests/views/connect-workshop-dispositions-search.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-workshop/dispositions-search ==="

NAVIGATE "/connect-workshop/dispositions-search"
WAIT 500
LOG "Verify: top-bar updated, dispositions table with action buttons"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-workshop/dispositions-search ==="
