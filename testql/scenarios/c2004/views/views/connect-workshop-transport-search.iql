# connect-workshop-transport-search.iql — Test: Warsztat > Transport
# URL: /connect-workshop/transport-search
# Run via: http://localhost:8105/files/tests/views/connect-workshop-transport-search.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-workshop/transport-search ==="

NAVIGATE "/connect-workshop/transport-search"
WAIT 500
LOG "Verify: top-bar updated, transport search with filters + table"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-workshop/transport-search ==="
