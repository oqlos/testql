# connect-test-full-test.iql — Test: Testowanie > Test automatyczny
# URL: /connect-test/full-test
# Run via: http://localhost:8105/files/tests/views/connect-test-full-test.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-test/full-test ==="

NAVIGATE "/connect-test/full-test"
WAIT 500
LOG "Verify: top-bar = 'Connect Test - Test automatyczny'"
LOG "Verify: device selector + scenario selector + start button"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
LOG "Verify: col3 = form elements (device/scenario selects, start button)"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-test/full-test ==="
