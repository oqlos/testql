# connect-test-testing-rfid.iql — Test: Testowanie > RFID
# URL: /connect-test/testing-rfid
# Run via: http://localhost:8105/files/tests/views/connect-test-testing-rfid.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-test/testing-rfid ==="

NAVIGATE "/connect-test/testing-rfid"
WAIT 500
LOG "Verify: top-bar updated, test categories (functional + reliability)"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
LOG "Verify: col3 = test-suite items (test categories)"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-test/testing-rfid ==="
