# connect-test-testing-qr.iql — Test: Testowanie > QR
# URL: /connect-test/testing-qr
# Run via: http://localhost:8105/files/tests/views/connect-test-testing-qr.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-test/testing-qr ==="

NAVIGATE "/connect-test/testing-qr"
WAIT 500
LOG "Verify: top-bar updated, QR device scan + test selector"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-test/testing-qr ==="
