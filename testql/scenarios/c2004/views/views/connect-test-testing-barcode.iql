# connect-test-testing-barcode.iql — Test: Testowanie > Barcode
# URL: /connect-test/testing-barcode
# Run via: http://localhost:8105/files/tests/views/connect-test-testing-barcode.iql

SET encoder_url "http://localhost:8105"
LOG "=== View: connect-test/testing-barcode ==="

NAVIGATE "/connect-test/testing-barcode"
WAIT 500
LOG "Verify: top-bar updated, barcode scan + device info + test checkboxes"

ENCODER_ON
WAIT 300
ENCODER_FOCUS "col3"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS
ENCODER_DBLCLICK
WAIT 200
ENCODER_OFF
WAIT 200
LOG "=== DONE: connect-test/testing-barcode ==="
