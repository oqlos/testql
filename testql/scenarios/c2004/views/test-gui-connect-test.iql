# test-gui-connect-test.iql — GUI tests for Connect Test module
# Tests: mouse+keyboard navigation, encoder navigation, page content verification
# Usage: python -m interpreter.iql tests/test-gui-connect-test.iql
#   or:  python -m interpreter.iql --dry-run tests/test-gui-connect-test.iql

SET encoder_url "http://localhost:8105"
SET api_url "http://localhost:8101"

LOG "=== Connect Test — GUI Test Suite ==="

# ═══════════════════════════════════════════════════════════════════════════════
# Part 1: Mouse + Keyboard Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 1: Mouse + Keyboard ---"

# 1.1 Navigate to Connect Test module
NAVIGATE "/connect-test"
WAIT 500
LOG "Verify: top-bar-section-title updated, no page-header in page-content"

# 1.2 Testing RFID subpage
NAVIGATE "/connect-test/testing-rfid"
WAIT 300
LOG "Verify: test suite with functional + reliability test categories"

# 1.3 Testing QR subpage
NAVIGATE "/connect-test/testing-qr"
WAIT 300
LOG "Verify: QR device scan + device info + test selector"

# 1.4 Testing Search subpage (main interactive page)
NAVIGATE "/connect-test/testing-search"
WAIT 300
LOG "Verify: search bar + filter buttons + device result list with actions"

# 1.5 Click search button
CLICK "[data-action='search-devices']"
WAIT 500
LOG "Verify: device list populated from API"

# 1.6 Testing Barcode subpage
NAVIGATE "/connect-test/testing-barcode"
WAIT 300
LOG "Verify: barcode scanner + device info + test checkboxes"

# 1.7 Device search subpage
NAVIGATE "/connect-test/devices-search"
WAIT 300
LOG "Verify: device search table with filters"

# 1.8 Scenario view subpage
NAVIGATE "/connect-test/scenario-view"
WAIT 300
LOG "Verify: scenario selector + DSL viewer"

# 1.9 Test run subpage
NAVIGATE "/connect-test/test-run"
WAIT 300
LOG "Verify: test execution interface"

# 1.10 Protocols subpage
NAVIGATE "/connect-test/protocols"
WAIT 300
LOG "Verify: protocols list"

# ═══════════════════════════════════════════════════════════════════════════════
# Part 2: Encoder Navigation
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 2: Encoder Mode ---"

# 2.1 Activate and navigate to Connect Test
ENCODER_ON
WAIT 300
ENCODER_FOCUS "col1"
WAIT 200

# 2.2 Navigate to Connect Test in main menu
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.3 Confirm → enter col2 (Connect Test submenu)
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: col2 shows Connect Test submenu items"

# 2.4 Scroll through submenu
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.5 Select Testing Search → enter col3
ENCODER_CLICK
WAIT 500
ENCODER_STATUS
LOG "Verify: col3 shows search results (data-enc-zone='col3')"

# 2.6 Navigate search results
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 2.7 Click result row → col4 (device actions)
ENCODER_CLICK
WAIT 300
ENCODER_STATUS
LOG "Verify: col4 shows Testuj/Szczegóły buttons (data-enc-zone='col4')"

# 2.8 Click action button (Testuj)
ENCODER_CLICK
WAIT 300
LOG "Verify: test action triggered"

# 2.9 Cancel back through zones
ENCODER_DBLCLICK
WAIT 200
ENCODER_DBLCLICK
WAIT 200
ENCODER_DBLCLICK
WAIT 200
ENCODER_STATUS
LOG "Verify: back to col1"

ENCODER_OFF
WAIT 200

# ═══════════════════════════════════════════════════════════════════════════════
# Part 3: API Verification
# ═══════════════════════════════════════════════════════════════════════════════

LOG "--- Part 3: API Verification ---"

API GET "/api/v3/data/devices?limit=5"
ASSERT_OK
LOG "Devices API accessible"

API GET "/api/v3/data/test_scenarios?limit=5"
ASSERT_OK
LOG "Scenarios API accessible"

API GET "/api/v3/data/protocols?limit=5"
ASSERT_OK
LOG "Protocols API accessible"

LOG "=== Connect Test — GUI Test Complete ==="
