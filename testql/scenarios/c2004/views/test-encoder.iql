# test-encoder.iql — Encoder navigation tests via IQL
# Requires: encoder-control service on port 8105 + browser with client.js loaded
# Usage: python -m testql.cli testql/scenarios/c2004/views/test-encoder.iql
#   or:  python -m testql.cli testql/scenarios/c2004/views/test-encoder.iql --dry-run

SET encoder_url "http://localhost:8105"
LOG "=== Encoder Navigation Test ==="

# 1. Activate encoder
ENCODER_ON
WAIT 300
ENCODER_STATUS

# 2. Navigate col1 (main menu) — scroll down through menu items
LOG "--- col1: Main Menu ---"
ENCODER_FOCUS "col1"
WAIT 200
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 3. Confirm selection → move to col2
LOG "--- col1 → col2: Click to enter submenu ---"
ENCODER_CLICK
WAIT 500
ENCODER_STATUS

# 4. Navigate col2 (submenu)
LOG "--- col2: Submenu ---"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 5. Confirm selection → move to col3
LOG "--- col2 → col3: Click to enter page content ---"
ENCODER_CLICK
WAIT 500
ENCODER_STATUS

# 6. Navigate col3 (page content / table rows)
LOG "--- col3: Page Content ---"
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_SCROLL 1
WAIT 150
ENCODER_STATUS

# 7. Table pagination (if table has pages)
LOG "--- col3a/col3b: Table Pagination ---"
ENCODER_PAGE_NEXT
WAIT 300
ENCODER_STATUS
ENCODER_PAGE_PREV
WAIT 300
ENCODER_STATUS

# 8. Click on table row → move to col4 (row actions)
LOG "--- col3 → col4: Click row to see actions ---"
ENCODER_CLICK
WAIT 500
ENCODER_STATUS

# 9. Cancel (double-click) → back to col3
LOG "--- col4 → col3: Cancel to go back ---"
ENCODER_DBLCLICK
WAIT 300
ENCODER_STATUS

# 10. Cancel again → back to col2
LOG "--- col3 → col2: Cancel again ---"
ENCODER_DBLCLICK
WAIT 300
ENCODER_STATUS

# 11. Cancel again → back to col1
LOG "--- col2 → col1: Cancel again ---"
ENCODER_DBLCLICK
WAIT 300
ENCODER_STATUS

# 12. Deactivate
ENCODER_OFF
WAIT 200
ENCODER_STATUS

LOG "=== Encoder Test Complete ==="
