# DSL Mixed Workflow Example
# This script demonstrates unified DSL format
# Works in BOTH browser (dsl.replay) and CLI (python3 dsl-cli.py)
#
# Run: python3 scripts/dsl-cli.py scripts/examples/test-mixed-workflow.dsl -u http://localhost:8101

LOG "🚀 Starting mixed workflow test" {"level": "info"}

# ============================================================================
# PART 1: API Tests (Universal - runs in CLI and Browser)
# ============================================================================

API GET "/api/v3/data/devices?limit=3"
ASSERT_STATUS 200
LOG "✅ Devices API works" {"level": "info"}

API GET "/api/v3/data/customers?limit=3"
ASSERT_STATUS 200
LOG "✅ Customers API works" {"level": "info"}

API GET "/api/v3/data/intervals?limit=3"
ASSERT_STATUS 200
LOG "✅ Intervals API works" {"level": "info"}

# ============================================================================
# PART 2: Browser Navigation (Browser only - CLI skips)
# ============================================================================

NAVIGATE "/connect-test-device"
WAIT 500

CLICK "[data-id='d-001'] .btn-test"
WAIT 300

SELECT "#interval-select" {"value": "36m"}
CLICK "#interval-start"

# ============================================================================
# PART 3: Semantic Actions (Logged in both, executed in browser only)
# ============================================================================

SELECT_DEVICE "d-001" {"serial": "AO73138", "type": "MSA_G1"}
SELECT_INTERVAL "36m" {"label": "36 miesięcy"}
START_TEST "ts-c20" {"scenario": "C20 standard"}

# ============================================================================
# PART 4: More API Tests (Universal)
# ============================================================================

API GET "/api/v3/data/protocols?limit=3"
ASSERT_STATUS 200
LOG "✅ Protocols API works" {"level": "info"}

API GET "/api/v3/data/test_scenarios?limit=3"
ASSERT_STATUS 200
LOG "✅ Scenarios API works" {"level": "info"}

# ============================================================================
# SUMMARY
# ============================================================================

LOG "🏁 Mixed workflow test completed" {"level": "info"}
LOG "📊 Results: API tests passed, browser actions logged" {"level": "info"}
