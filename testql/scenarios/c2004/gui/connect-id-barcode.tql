# connect-id-barcode.tql — GUI test for ID barcode scanning view
# Usage: testql scenarios/c2004/gui/connect-id-barcode.tql --url http://localhost:8101

LOG "=== GUI: ID / Barcode ==="

NAVIGATE "/connect-id-barcode"
WAIT 500

ASSERT_VISIBLE "[data-view='id-barcode']"
LOG "barcode view loaded"

INPUT "#barcode-input" "4542345678"
WAIT 200
CLICK "[data-action='scan']"
WAIT 300
LOG "barcode submitted"

LOG "=== ID Barcode PASSED ==="
