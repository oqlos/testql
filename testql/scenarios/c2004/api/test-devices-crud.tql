# test-devices-crud.tql — full CRUD test for devices API
# Usage: testql scenarios/c2004/api/test-devices-crud.tql --url http://localhost:8101

LOG "=== Devices CRUD Test ==="

# LIST
API GET "/api/v3/data/devices"
ASSERT_STATUS 200
ASSERT_JSON data.length > 0
LOG "LIST devices OK"

# CREATE
API POST "/api/v3/data/devices" {"serial_number": "TQL-TEST-001", "device_type": "mask", "manufacturer": "Dräger", "model": "Panorama Nova"}
ASSERT_OK
LOG "CREATE device OK"

# READ
API GET "/api/v3/data/devices?search=TQL-TEST-001"
ASSERT_STATUS 200
ASSERT_CONTAINS "TQL-TEST-001"
LOG "READ device OK"

# DELETE (cleanup)
API DELETE "/api/v3/data/devices/TQL-TEST-001"
ASSERT_OK
LOG "DELETE device OK"

LOG "=== Devices CRUD PASSED ==="
