# test-protocol-flow.tql — protocol creation and completion flow
# Usage: testql scenarios/c2004/api/test-protocol-flow.tql --url http://localhost:8101

LOG "=== Protocol Flow Test ==="

# Create a protocol
API POST "/api/v3/data/protocols" {"device_id": "dev-test-001", "scenario_id": "ts-szczelnosc-maski", "operator": "testql"}
ASSERT_OK
LOG "protocol created"

# List protocols
API GET "/api/v3/data/protocols"
ASSERT_STATUS 200
LOG "protocols listed"

# Fetch latest
API GET "/api/v3/data/protocols?limit=1&sort=created_at:desc"
ASSERT_STATUS 200
LOG "latest protocol fetched"

LOG "=== Protocol Flow PASSED ==="
