# DSL Session Recording
# Session: Test device workflow - MSA_G1 periodic test
# Started: 2025-12-04T14:00:00.000Z
# Entries: 15
#
# This script was generated by the DSL Session Recorder
# Run with: python3 scripts/dsl-cli.py scripts/examples/recorded-test-session.dsl
# Or replay in browser: dslRecord.replay(`<script>`)

LOG "Session start" {"id": "session-example"}

# Navigate to device search page
NAVIGATE "/connect-test-device"
WAIT 500

# Click on test button for device d-001
CLICK "[data-id='d-001'] .btn-test-item" {"label": "🧪"}

# Open interval selection for device
OPEN_INTERVAL_DIALOG "d-001" {"customerId": "cu-001"}
WAIT 300

# Select interval - periodic 36 months
SELECT "#interval-select" {"value": "36m", "text": "36 miesięcy"}
SELECT_INTERVAL "36m" {"deviceId": "d-001"}

# Start the test
CLICK "#interval-start" {"action": "confirm_interval"}
START_TEST "ts-c20" {"interval": "36m", "deviceId": "d-001", "deviceType": "MSA_G1"}

# Test parameters parsed
# Test parameters: {"customer":"cu-001","device":"","device_id":"d-001","type":"36m"}

# Protocol created
# Protocol created: pro-example123

# Navigate to protocol steps
NAVIGATE "/connect-test-protocol?protocol=pro-example123&step=1" {"protocol": "pro-example123"}
WAIT 500

# Complete first step
CLICK ".btn.btn-primary" {"label": "OK"}
STEP_COMPLETE "step-1" {"name": "Wytworzyć podciśnienie", "status": "passed"}

# Complete final step
CLICK ".btn.btn-primary" {"label": "OK"}
STEP_COMPLETE "final" {"name": "Uwagi końcowe", "status": "passed"}

# Finalize protocol
PROTOCOL_FINALIZE "pro-example123" {"status": "executed"}

# Navigate to report
NAVIGATE "/connect-test/reports?protocol=pro-example123"

LOG "Session complete" {"entries": 15}
