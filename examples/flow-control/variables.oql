# SCENARIO: Variables and Interpolation
# TYPE: flow

SET base_url "http://localhost:8101"
SET timeout_ms 5000
SET device_id "dev-001"

LOG "Starting test for device: ${device_id}"
LOG "Base URL is: $base_url"
GET base_url
GET timeout_ms

WAIT 100

API GET "${base_url}/api/health"
ASSERT_STATUS 200

LOG "Test completed successfully"
