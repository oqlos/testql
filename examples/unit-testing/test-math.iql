# SCENARIO: Unit Testing — Math Module
# TYPE: unit

LOG "Testing math module import"
UNIT_IMPORT "math"

LOG "Testing basic math assertion"
UNIT_ASSERT "math.sqrt(16) == 4"

LOG "Testing string manipulation"
UNIT_ASSERT "'hello'.upper() == 'HELLO'"

LOG "Testing list comprehension"
UNIT_ASSERT "[x*2 for x in [1,2,3]] == [2,4,6]"
