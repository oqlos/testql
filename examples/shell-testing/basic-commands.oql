# SCENARIO: Basic Shell Commands Test
# TYPE: shell

LOG "Testing basic shell commands"

# Test echo command (real execution needed for stdout checks)
SHELL "echo Hello TestQL"
ASSERT_EXIT_CODE 0

# Test command with exit code
RUN ls -la
ASSERT_EXIT_CODE 0

# Test non-existent command — requires real execution (dry-run returns 0)
RUN nonexistent-command-12345
ASSERT_EXIT_CODE 0
