# C2004 visual-testing targets (moved from the repo-root Makefile).
# Run from this directory: make -C tools/c2004-visual testql-encoder

# TestQL Testing Targets
.PHONY: testql-encoder testql-menu testql-parallel testql-visual testql-all testql-results

testql-encoder:
	@echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
